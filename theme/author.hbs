{{!< default}}

{{#contentFor 'title'}}{{ meta_title }}{{/contentFor}}

{{#author}}
  <header class='c-page-header'>
    <div class='o-grid o-grid--2-columns'>
      <div>
        {{#if profile_image}}
          <figure class='c-author__media u-mb-16'>
            <img
              alt=''
              loading='lazy'
              decoding='async'
              class='c-author__image'
              width='96' height='96'
              src='{{ img_url profile_image size='profile-image' format='webp' }}'
            >
          </figure>
        {{/if}}

        <h1 class='u-font-headline'>{{ name }}</h1>

        {{#if bio}}
          <p class='c-page-header__excerpt u-font-standfirst u-mt-8'>{{ bio }}</p>
        {{/if}}

        <div class='u-color-text-secondary u-mt-16'>
          {{#if website}}
            <a href='{{ website }}' class='u-link u-mr-8'>Website</a>
          {{/if}}

          {{#if twitter}}
            <a href='{{social_url type="twitter"}}' class='u-link u-mr-8'>𝕏</a>
          {{/if}}

          {{#if facebook}}
            <a href='{{social_url type="facebook"}}' class='u-link u-mr-8'>Facebook</a>
          {{/if}}

          {{#if linkedin}}
            <a href='{{social_url type="linkedin"}}' class='u-link u-mr-8'>LinkedIn</a>
          {{/if}}
          
          {{#if bluesky}}
            <a href='{{social_url type="bluesky"}}' class='u-link u-mr-8'>Bluesky</a>
          {{/if}}

          {{#if threads}}
            <a href='{{social_url type="threads"}}' class='u-link u-mr-8'>Threads</a>
          {{/if}}

          {{#if mastodon}}
            <a href='{{social_url type="mastodon"}}' class='u-link u-mr-8'>Mastodon</a>
          {{/if}}

          {{#if tiktok}}
            <a href='{{social_url type="tiktok"}}' class='u-link u-mr-8'>TikTok</a>
          {{/if}}

          {{#if youtube}}
            <a href='{{social_url type="youtube"}}' class='u-link u-mr-8'>YouTube</a>
          {{/if}}

          {{#if instagram}}
            <a href='{{social_url type="instagram"}}' class='u-link u-mr-8'>Instagram</a>
          {{/if}}

          {{#if location}}{{ location }}{{/if}}
        </div>
      </div>
    </div>
  </header>
{{/author}}

{{> loop }}

{{ pagination }}