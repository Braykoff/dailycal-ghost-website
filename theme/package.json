{
  "name": "dc-theme",
  "description": "Daily Californian Ghost CMS Theme, built from Tripoli",
  "demo": "https://tripoli.aspirethemes.com/",
  "docs": "https://aspirethemes.com/docs/tripoli",
  "version": "1.2.0",
  "engines": {
    "ghost": ">=5.0.0"
  },
  "keywords": [
    "ghost-theme"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "bower install",
    "build": "gulp build"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "bower": "^1.8.14",
    "evil-icons": "^1.10.1",
    "fslightbox": "^3.7.5",
    "gulp-postcss": "^10.0.0",
    "install": "^0.13.0",
    "modern-normalize": "^3.0.1",
    "postcss": "^8.5.13",
    "prismjs": "^1.30.0",
    "sass-mq": "^7.0.0",
    "tocbot": "^4.36.6"
  },
  "devDependencies": {
    "concat": "^3.0.0",
    "fs": "^0.0.2",
    "gulp": "^5.0.1",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-jshint": "^2.1.0",
    "gulp-rename": "^2.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-rtlcss": "^2.0.0",
    "gulp-sass": "^6.0.1",
    "gulp-uglify": "^3.0.2",
    "gulp-zip": "^6.1.0",
    "jshint": "^2.13.6",
    "jshint-stylish": "^2.2.1",
    "run-sequence": "^2.2.1",
    "sass": "^1.99.0"
  },
  "author": {
    "name": "Aspire Themes",
    "email": "ahmad@aspirethemes.com",
    "url": "https://aspirethemes.com/"
  },
  "config": {
    "custom": {
      "enable_right_to_left_layout": {
        "type": "boolean",
        "default": false
      },
      "enable_search": {
        "type": "boolean",
        "default": true
      },
      "enable_post_access_label": {
        "type": "boolean",
        "default": false
      },
      "enable_post_card_excerpt": {
        "type": "boolean",
        "default": true
      },
      "enable_table_of_contents": {
        "type": "boolean",
        "default": true,
        "group": "post"
      },
      "enable_dark_mode": {
        "type": "boolean",
        "default": false
      },
      "dark_mode_accent_color": {
        "type": "color",
        "default": "#F0A45C"
      },
      "dark_mode_publication_logo": {
        "type": "image"
      },
      "date_format": {
        "type": "select",
        "options": [
          "Month - Day - Year",
          "Day - Month - Year",
          "Year - Month - Day",
          "TimeAgo",
          "Hide Date"
        ],
        "default": "Month - Day - Year"
      },
      "linkedin_page": {
        "type": "text",
        "default": "https://www.linkedin.com/company/the-daily-californian"
      },
      "bluesky_page": {
        "type": "text",
        "default": ""
      },
      "mastodon_page": {
        "type": "text",
        "default": ""
      },
      "youtube_page": {
        "type": "text",
        "default": "https://www.youtube.com/thedailycal"
      },
      "instagram_page": {
        "type": "text",
        "default": "https://www.instagram.com/dailycal/"
      },
      "pinterest_page": {
        "type": "text",
        "default": ""
      },
      "discord_page": {
        "type": "text",
        "default": ""
      },
      "number_of_latest_posts": {
        "type": "text",
        "default": "6",
        "group": "homepage"
      },
      "tag_slugs_for_home_sections": {
        "type": "text",
        "group": "homepage"
      },
      "number_of_posts_for_tags_home_sections": {
        "type": "text",
        "default": "4",
        "group": "homepage"
      },
      "number_of_editors_picks_posts": {
        "type": "text",
        "default": "3",
        "group": "homepage"
      }
    },
    "card_assets": {
      "exclude": [
        "button",
        "blockquote",
        "bookmark",
        "image",
        "gallery"
      ]
    },
    "posts_per_page": 16,
    "image_sizes": {
      "profile-image": {
        "width": 384
      },
      "feature-image": {
        "width": 652
      },
      "feature-image-large": {
        "width": 1304
      }
    }
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  }
}
