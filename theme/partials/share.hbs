<ul class='c-share u-plain-list'>
  {{!-- X, formerly known as Twitter --}}
  <li class='c-share__item'>
    <a class='c-share__link' aria-label="{{t 'Share on 𝕏' }}"
       href="https://twitter.com/share?text={{ encode title }}&amp;url={{ url absolute='true' }}"
       onclick="window.open(this.href, 'twitter-share', 'width=550, height=235'); return false;">
      {{> icons/twitter-x }}
    </a>
  </li>

  {{!-- Facebook --}}
  <li class='c-share__item'>
    <a class='c-share__link'
       href="https://www.facebook.com/sharer/sharer.php?u={{ url absolute='true' }}"
       onclick="window.open(this.href, 'facebook-share', 'width=580, height=296'); return false;">
      {{> icons/facebook }}
      <span class='u-screenreader'>{{t 'Share on Facebook' }}</span>
    </a>
  </li>

  {{!-- Pinterest --}}
  <li class='c-share__item'>
    <a class='c-share__link'
      href="http://pinterest.com/pin/create/button/?url={{ url absolute='true' }}&media={{ feature_image }}&description={{ encode title }}"
      onclick="window.open(this.href, 'pinterest-share', 'width=580, height=296'); return false;">
      {{> icons/pinterest }}
      <span class='u-screenreader'>{{t 'Share on Pinterest' }}</span>
    </a>
  </li>

  {{!-- LinkedIn --}}
  <li class='c-share__item'>
    <a class='c-share__link'
      href="https://www.linkedin.com/shareArticle?mini=true&url={{ url absolute='true' }}&title={{ encode title }}"
      onclick="window.open(this.href, 'linkedin-share', 'width=580, height=296'); return false;">
      {{> icons/linkedin }}
      <span class='u-screenreader'>{{t 'Share on LinkedIn' }}</span>
    </a>
  </li>

  {{!-- Whatsapp --}}
  <li class='c-share__item'>
    <a class='c-share__link' href="whatsapp://send?text={{ encode title }} {{ url absolute='true' }}">
      {{> icons/whatsapp }}
      <span class='u-screenreader'>{{t 'Share on WhatsApp' }}</span>
    </a>
  </li>

  {{!-- Email --}}
  <li class='c-share__item'>
    <a class='c-share__link'
       href="mailto:?subject={{ encode title }}&body={{ url absolute='true' }}">
      {{> icons/email }}
      <span class='u-screenreader'>{{t 'Share via Email' }}</span>
    </a>
  </li>

  {{!-- Print --}}
  <li class='c-share__item'>
    <a class='c-share__link' aria-label="{{t 'Print' }}"
       href="javascript:void(0)"
       onclick="window.print();">
      {{> icons/printer }}
    </a>
  </li>
</ul>